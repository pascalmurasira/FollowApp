default_platform(:ios)

platform :ios do
  desc 'Build a signed FollowApp archive for App Store Connect'
  lane :build_app_store do
    setup_ci if ENV['CI']

    increment_build_number(
      xcodeproj: 'App/App.xcodeproj',
      build_number: ENV['BUILD_NUMBER'] || Time.now.utc.strftime('%Y%m%d%H%M')
    )

    build_app(
      project: 'App/App.xcodeproj',
      scheme: 'App',
      export_method: 'app-store',
      xcargs: '-allowProvisioningUpdates',
      export_xcargs: '-allowProvisioningUpdates',
      export_options: {
        signingStyle: 'manual',
        signingCertificate: 'Apple Distribution',
        teamID: 'ZF489NYM57',
        provisioningProfiles: {
          'com.pascalmurasira.followapp' => 'FollowApp App Store',
          'com.pascalmurasira.followapp.widgets' => 'FollowApp Widgets App Store',
          'com.pascalmurasira.followapp.capture' => 'FollowApp Camera Capture App Store'
        },
        manageAppVersionAndBuildNumber: false,
        stripSwiftSymbols: true,
        uploadSymbols: true
      },
      output_directory: '../build',
      output_name: 'FollowApp.ipa'
    )
  end

  desc 'Upload the latest FollowApp archive to TestFlight'
  lane :testflight do
    build_app_store
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end
